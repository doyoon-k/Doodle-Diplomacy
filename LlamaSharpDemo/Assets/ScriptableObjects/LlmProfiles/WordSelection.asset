--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: WordSelection
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/gemma-3-4b-it-q4_0.gguf
  format: '{"type":"object","properties":{"words":{"type":"array","items":{"type":"string"}}},"required":["words"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You are a quiz word-pair generator.

    Select 2 objects
    and respond in JSON only. Do not include any other text.



    Rules:

    -
    Pick one from each of two different domains (nature / man-made / food / body
    / science / history / mythology / etc.)

    - No direct associations between
    the two (toothbrush + toothpaste X)

    - Common enough to be recognizable,
    but not too obvious

    - Concrete nouns only (no abstract concepts)'
  jsonSchemaDeliveryMode: 0
  jsonFields:
  - fieldName: words
    fieldType: 5
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0.7
    top_p: 0.9
    top_k: 40
    num_predict: 0
    repeat_penalty: 1.1
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 1024
    gpuLayerCount: 999
    threads: 4
