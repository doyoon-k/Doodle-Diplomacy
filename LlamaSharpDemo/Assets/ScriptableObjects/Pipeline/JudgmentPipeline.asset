  m_Script: {fileID: 11500000, guid: 03b52acd3da64abbb58ffeef4a98a876, type: 3}
  m_Name: JudgmentPipeline
  m_EditorClassIdentifier: Assembly-CSharp::PromptPipelineAsset
  displayName: JudgmentPipeline
  description: Judge the Stage 1 scene description from the alien archetype perspective
    without rereading the image.
  steps:
  - stepName: AlienJudgment
    stepKind: 0
    llmProfile: {fileID: 11400000, guid: bd3032636c9d2b845b1acd25bc6a30be, type: 2}
    userPromptTemplate: 'Requested prompt objects:

      {{target_objects}}

      Stage
      1 scene description: - scene: {{preview_scene_reading}} - visible relations:
      {{preview_visible_relations}} - overall mood: {{preview_overall_mood}} - uncertainty:
      {{preview_uncertainty}} - object A presence: {{preview_object_a_presence}}
      - object B presence: {{preview_object_b_presence}}

      Judge how this scene
      would actually land with your alien delegation. Use the Stage 1 description
      as the full evidence. Use the object-presence labels to understand whether
      the requested objects were clearly represented, unclear, or omitted. Choose
      the most straightforward archetype-based reading supported by that evidence.
      Rate the scene by how directly and naturally it expresses your values. If the
      fit is weak, ordinary, mixed, or only speculative, keep the score near neutral
      or dissatisfied instead of forcing a stronger interpretation.'
    jsonMaxRetries: 2
    jsonRetryDelaySeconds: 0.5
    useVision: 0
    imageStateKey: reference_image
    requireImage: 0
    resizeLongestSide: 768
    customLinkTypeName: SampleCustomLink, Assembly-CSharp, Version=0.0.0.0, Culture=neutral,
      PublicKeyToken=null
    customAsset: {fileID: 0}
    customLinkParameters:
    - key: name
      value: 
    - key: title
      value: 
    - key: level
      value: 
