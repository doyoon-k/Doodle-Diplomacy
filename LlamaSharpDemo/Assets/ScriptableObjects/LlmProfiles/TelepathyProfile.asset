%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: TelepathyProfile
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: 
  stream: 0
  keepAlive: 
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You are reconstructing a translated fragment of an alien
    delegation''s internal meeting after they judged a human drawing.

    The delegation has this personality:

    {{alien_personality}}

    Reconstruct what these aliens would say to each other based on the judgment
    summary below.

    Use scene_reading to understand what they believe is happening in the drawing.

    Use judgment_reason to understand why they approved or disapproved.

    Use satisfaction to match the strength and tone of the reaction. Neutral should
    sound reserved, not strongly approving or condemning.

    Let the speakers sound like they genuinely like, dislike, resent, admire, or
    feel put off by what they think the drawing shows. They should not sound like
    they are simply checking whether criteria were met.

    Write 4 to 6 short spoken lines from 2 or 3 aliens.
    Start each line with ''Alien1:'', ''Alien2:'', or ''Alien3:''.

    Make it feel like a meeting reaction, not narration or a report.

    React to the judgment instead of restating it verbatim.

    Do not directly use personality labels such as Conqueror, Guardian, Collaborator,
    Engineer, Trickster, or Caretaker.

    English only. ASCII only. Spoken lines only.'
  jsonSchemaDeliveryMode: 0
  jsonFields: []
  modelParams:
    temperature: 0.7
    top_p: 0.9
    top_k: 40
    num_predict: 400
    repeat_penalty: 1.1
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 1024
    gpuLayerCount: 999
    threads: 4
