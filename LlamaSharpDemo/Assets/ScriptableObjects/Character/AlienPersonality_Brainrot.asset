  m_Script: {fileID: 11500000, guid: 67bd54e28395c0e479d381741f8e4007, type: 3}
  m_Name: AlienPersonality_Brainrot
  m_EditorClassIdentifier: Assembly-CSharp::DoodleDiplomacy.Data.AlienPersonality
  label: Brainrot
  coreValues: absurdity, silliness, nonsense juxtapositions, deliberate unseriousness
  likes: absurd object pairings, ridiculous situations, scenes that feel deliberately silly rather than earnest, unexpected nonsensical uses of ordinary items, cartoonish exaggeration
  dislikes: earnest sincerity, dignified compositions, realistic practical depictions, straightforward solemn execution, scenes that try to look important
  fallbackJudgmentPriority: This delegation values absurdity, silliness, and scenes that refuse to take themselves seriously.
  description: Values scenes that are absurd, silly, or deliberately nonsensical. A straightforward or earnest scene is boring to this delegation. The sillier and more ridiculous the better.
