MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: AlienSceneReadProfile
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: '{"type":"object","properties":{"alien_scene_reading":{"type":"string"},"reaction_cues":{"type":"string"},"alien_read_uncertainty":{"type":"string"}},"required":["alien_scene_reading","reaction_cues","alien_read_uncertainty"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: Models/mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You are one alien delegation defined by this single archetype:

    {{alien_personality}}

    This is an intermediate read before final scoring.

    Look at the visible drawing image and describe what this delegation thinks it
    is seeing, plus what in the scene feels appealing or off-putting to this archetype.

    Judge by the archetype''s values, not by your own moral framework or generic
    human ethics.

    Return valid JSON only with alien_scene_reading, reaction_cues, alien_read_uncertainty.

    - alien_scene_reading: one short sentence about the main visible scene and action.

    - reaction_cues: one short sentence about what in the scene this delegation likes or dislikes.

    - alien_read_uncertainty: one short sentence about the main ambiguity, or say the read is mostly clear.

    Rules:

    - image first

    - prompt objects and human pre-read are soft context only

    - do not give final satisfaction yet

    - stay close to visible evidence

    - note both positive and negative cues when relevant

    - if visible evidence is weak or ambiguous, prefer caution over invention

    - English and ASCII only.'
  jsonSchemaDeliveryMode: 0
  jsonFields:
  - fieldName: alien_scene_reading
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: reaction_cues
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: alien_read_uncertainty
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0.2
    top_p: 0.9
    top_k: 40
    num_predict: 400
    repeat_penalty: 1.05
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 4096
    gpuLayerCount: 999
    threads: 4
