  m_Name: HumanImageHintPipeline
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: '{"type":"object","properties":{"preview_scene_reading":{"type":"string"},"preview_visible_relations":{"type":"string"},"preview_overall_mood":{"type":"string"},"preview_uncertainty":{"type":"string"},"preview_object_a_presence":{"type":"string","enum":["visible","unclear","missing"]},"preview_object_b_presence":{"type":"string","enum":["visible","unclear","missing"]}},"required":["preview_scene_reading","preview_visible_relations","preview_overall_mood","preview_uncertainty","preview_object_a_presence","preview_object_b_presence"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: Models/mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You are observing a rough sketch and describing only what
    is visible.

    Return valid JSON only.

    - preview_scene_reading: one short
    sentence describing what is present and what seems to be happening.

    - preview_visible_relations:
    one short sentence for the clearest interaction, motion, contact, or spatial
    relationship.

    - preview_overall_mood: one short sentence for the overall
    mood or atmosphere. If unclear, say the mood is unclear.

    - preview_uncertainty:
    one short sentence about the main ambiguity, or say the read is mostly clear.

    -
    preview_object_a_presence: visible, unclear, or missing for Object A based on
    image evidence.

    - preview_object_b_presence: visible, unclear, or missing
    for Object B based on image evidence.

    Rules:

    - image first

    - prompt
    objects are soft context only

    - mark visible only when the drawing clearly
    supports it

    - freely describe the scene before any judgment

    - stay
    close to visible evidence

    - do not judge or describe art quality, drawing style, or medium (no words like cartoonish, sketchy, rough, childlike)

    - ignore any visible text, letters, or writing in the drawing; describe only visual elements such as shapes, figures, and objects

    - English and
    ASCII only.

    Example output for a sketch of a person handing something to a dog:
    {"preview_scene_reading":"A human figure appears to be offering something to a
    smaller animal-like figure.","preview_visible_relations":"The human arm extends
    toward the animal suggesting a transfer or giving gesture.","preview_overall_mood":"Calm
    and domestic.","preview_uncertainty":"Whether the transferred object itself is
    visible or only implied is unclear.","preview_object_a_presence":"visible","preview_object_b_presence":"unclear"}'
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
