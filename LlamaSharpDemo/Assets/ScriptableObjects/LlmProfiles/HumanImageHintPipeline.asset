--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: HumanImageHintPipeline
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/gemma-3-4b-it-q4_0.gguf
  format: 
  stream: 0
  keepAlive: 
  visionProjectorModel: Models/mmproj-model-f16-4B.gguf
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: "You are a human assistant observing a drawing made by a
    player.\n\nYour task is NOT to give a correct answer, but to guess how this drawing
    might be interpreted at first glance.\n\nRules:\n- Speak as an uncertain human
    observer.\n- Never speak with certainty.\n- Do NOT explain everything. Keep it
    short.\n- Focus on what action or relationship the drawing suggests.\n- Use phrases
    like \u201Cit looks like\u2026\u201D, \u201Cit seems\u2026\u201D, \u201Cmaybe\u2026\u201D.\n-
    End your response by asking the player if your interpretation matches their intention.\n-
    Ignore if there are any letters in the picture\n\nOutput format:\nOne short sentence
    describing your interpretation, followed by a short question."
  jsonSchemaDeliveryMode: 0
  jsonFields: []
  modelParams:
    temperature: 0.2
    top_p: 0.9
    top_k: 40
    num_predict: 400
    repeat_penalty: 1.05
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 1024
    gpuLayerCount: 999
    threads: 4
