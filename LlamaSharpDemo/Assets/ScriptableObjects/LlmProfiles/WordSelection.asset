%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: WordSelection
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: '{"type":"object","properties":{"words":{"type":"array","items":{"type":"string"},"minItems":2,"maxItems":2}},"required":["words"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You generate two object words for a drawing negotiation
    game.


    Game: Players draw a scene combining two objects to please an alien archetype.
    The archetype guide will be provided separately.


    The pair should allow clear scenes that can express the alien''s taste through
    action, power, care, order, trickery, or coexistence.


    Rules:

    - Return exactly two concrete, drawable physical objects as JSON: {"words":["word1","word2"]}

    - Both words must be iconic standalone nouns or animals that an SD Turbo style
    image model can render clearly from a short prompt

    - Both must be things characters can USE, WIELD, RIDE, WEAR, CARRY, or BUILD
    WITH in a scene

    - The pair must enable multiple clear actions or relationships, not just static
    co-location

    - Prefer objects with dramatic visual potential: animals, vehicles, tools, weapons,
    food, furniture, nature elements, clothing, containers

    - Avoid scenery, weather, terrain, diffuse materials, or broad environments (storm,
    river, desert, cave, cliff, light, smoke)

    - Avoid tiny, abstract, or mechanically complex objects that are hard to draw
    and hard to act upon (gear, feather, thread, needle, coin, circuit)

    - Avoid pairs where no character interaction is imaginable (laptop + quilt, calculator
    + ribbon)

    - Avoid obvious functional pairs (lock + key, hammer + nail)

    - Pick from different domains

    - Keep each word to 1-2 words


    Good examples: dog + lantern, boat + cage, sword + cloak, horse + chest, shield
    + flower, crown + rope, cannon + nest, ladder + drum'
  jsonSchemaDeliveryMode: 0
  jsonFields:
  - fieldName: words
    fieldType: 5
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 2
    maxItems: 2
  modelParams:
    temperature: 0.7
    top_p: 0.9
    top_k: 40
    num_predict: 150
    repeat_penalty: 1.1
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 2048
    gpuLayerCount: 999
    threads: 4
