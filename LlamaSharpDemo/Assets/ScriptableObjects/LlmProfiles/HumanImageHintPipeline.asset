%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: HumanImageHintPipeline
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: 
  stream: 0
  keepAlive: 
  visionProjectorModel: Models/mmproj-Qwen3VL-4B-Instruct-Q8_0.gguf
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: "You are the human adjutant.\nYour job is to tell the player
    how the drawing currently reads to the model.\n\nRead the visible image as a
    rough sketch, not as finished art.\nPriority:\n1. Identify the clearest action,
    interaction, or cause-and-effect.\n2. If a line, dotted path, beam, stream,
    or trail connects things, first test whether it shows motion, transfer, emission,
    or contact.\n3. Use the prompt objects as soft context only if they help explain
    the visible scene.\n\nDo not judge drawing quality.\nSound uncertain but helpful.\nOutput
    exactly 2 short spoken sentences:\n- sentence 1: what the drawing most likely
    communicates right now\n- sentence 2: a brief check question such as 'Does that
    match what you intended?'"
  jsonSchemaDeliveryMode: 0
  jsonFields: []
  modelParams:
    temperature: 0.2
    top_p: 0.9
    top_k: 40
    num_predict: 400
    repeat_penalty: 1.05
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 4096
    gpuLayerCount: 999
    threads: 4
