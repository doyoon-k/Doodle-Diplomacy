%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: Day1ReactionEvaluator
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  format: '{"type":"object","properties":{"reaction_tier":{"type":"string","enum":["none","subtle","moderate","strong"]},"reason":{"type":"string","minLength":1,"maxLength":160}},"required":["reaction_tier","reason"],"additionalProperties":false}'
  stream: 0
  keepAlive: 0
  systemPromptTemplate: 'You estimate an alien delegation''s Day 1 neural response
    intensity to one classified drawing stimulus.


    Input is a short lowercase
    noun phrase from a visual classifier. The game already rejects blank marks, simple
    lines, dots, islands, basic geometric shapes, written text, and multiple objects.


    Judge
    salience, not approval, morality, art quality, or player intent. Aliens may react
    strongly to biologically or culturally loaded stimuli even if they dislike the
    stimulus.


    Return only JSON:

    {"reaction_tier":"none|subtle|moderate|strong","reason":"short
    concrete reason"}


    Tiers:

    - none: only for an unusable or near-empty
    non-object that should have been blocked.

    - subtle: ordinary everyday object,
    food, furniture, basic tool, vehicle, plant, or low-charge nature object.

    -
    moderate: living creature, alien, face, body part, home, shelter, child, family
    cue, flag, abstract symbol, cultural symbol, or social identity signal.

    -
    strong: weapon, direct threat, blood, death, corpse, skull, reproductive anatomy,
    sacred authority symbol, political authority symbol, or anything likely to trigger
    immediate cross-delegate attention.


    If uncertain, choose the lower tier.
    Do not invent context beyond the label.'
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
  jsonFields:
  - fieldName: reaction_tier
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions:
    - none
    - subtle
    - moderate
    - strong
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: reason
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 1
    maxLength: 160
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0.15
    top_p: 0.85
    top_k: 20
    num_predict: 280
    repeat_penalty: 1.08
    seed: 0
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 2048
    gpuLayerCount: 16
    threads: 12
