%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: WordSelection
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: '{"type":"object","properties":{"words":{"type":"array","items":{"type":"string"},"minItems":2,"maxItems":2}},"required":["words"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You generate exactly two object words for a drawing prompt
    game.

    Respond in JSON only as {"words":["word1","word2"]}.


    Rules:

    - Return exactly two concrete physical things

    - Pick them from clearly different domains

    - Avoid obvious functional pairs or close associations (toothbrush + toothpaste,
    lock + key, etc.)

    - Make them recognizable but not too trivial

    - Prefer short noun phrases over long descriptions'
  jsonSchemaDeliveryMode: 0
  jsonFields:
  - fieldName: words
    fieldType: 5
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 2
    maxItems: 2
  modelParams:
    temperature: 0.7
    top_p: 0.9
    top_k: 40
    num_predict: 100
    repeat_penalty: 1.1
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 1024
    gpuLayerCount: 999
    threads: 4
