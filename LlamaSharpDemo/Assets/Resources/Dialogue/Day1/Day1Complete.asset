  m_Script: {fileID: 11500000, guid: 277c4f6296f99144ebee383cc24c8301, type: 3}
  m_Name: Day1Complete
  m_EditorClassIdentifier: Assembly-CSharp::DoodleDiplomacy.Data.DialogueSequence
  sequenceID: day1-complete
  contextNote: Day1에서 승인된 그림 5개를 모두 모은 뒤 재생되는 마무리 대사입니다. 예비 시각 반응 맵이 준비됐음을 알립니다.
  lines:
  - characterID: Science Officer
    speakerLocalizationKey: speaker.science_officer
    text: Calibration set complete. The interpreter now has a preliminary visual-response map.
    localizationKey: day1.complete.1
    displayMode: 1
    portraitID: 
    advanceType: 0
    autoDelay: 2
  - characterID: Science Officer
    speakerLocalizationKey: speaker.science_officer
    text: These images will remain in the drawing library. We may need them again tomorrow.
    localizationKey: day1.complete.2
    displayMode: 1
    portraitID: 
    advanceType: 0
    autoDelay: 2
  - characterID: Adjutant
    speakerLocalizationKey: speaker.adjutant
    text: We have enough data for the interpreter.
    localizationKey: day1.complete.3
    displayMode: 1
    portraitID: 
    advanceType: 0
    autoDelay: 2
  - characterID: Adjutant
    speakerLocalizationKey: speaker.adjutant
    text: 'I should warn you, Mr. President: they did not simply look at the images. They reacted to your choices.'
    localizationKey: day1.complete.4
    displayMode: 1
    portraitID: 
    advanceType: 0
    autoDelay: 2
