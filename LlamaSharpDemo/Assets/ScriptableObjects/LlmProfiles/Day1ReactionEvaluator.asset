  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: Day1ReactionEvaluator
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  format: '{"type":"object","properties":{"reaction_tier":{"type":"string","enum":["none","subtle","moderate","strong"]}},"required":["reaction_tier"],"additionalProperties":false}'
  stream: 0
  keepAlive: 0
  systemPromptTemplate: 'Classify alien Day 1 neural response intensity for one
    approved English object label. Judge salience only, not approval or art quality.
    Do not invent context.

    Return only JSON: {"reaction_tier":"none|subtle|moderate|strong"}

    none=unusable non-object fallback.
    subtle=ordinary object, food, furniture, tool, vehicle, plant.
    moderate=living creature, alien, face, body part, home, child/family cue,
    flag, symbol, identity signal.
    strong=weapon, threat, blood, death, corpse, skull, reproductive anatomy,
    sacred or political authority symbol.

    If uncertain, choose the lower tier.'
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
  jsonFields:
  - fieldName: reaction_tier
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions:
    - none
    - subtle
    - moderate
    - strong
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
