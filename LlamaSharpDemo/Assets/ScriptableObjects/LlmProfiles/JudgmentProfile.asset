%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: JudgmentProfile
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  model: Models/Qwen3VL-4B-Instruct-Q4_K_M.gguf
  format: '{"type":"object","properties":{"satisfaction":{"type":"string","enum":["very_dissatisfied","dissatisfied","neutral","satisfied","very_satisfied"]},"scene_reading":{"type":"string"},"judgment_reason":{"type":"string"}},"required":["satisfaction","scene_reading","judgment_reason"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  visionProjectorModel: 
  visionProjectorRelativeToStreamingAssets: 1
  systemPromptTemplate: 'You are an alien who is deeply immersed in this archetype:

    {{alien_personality}}

    You see everything through the lens of these values. When you look at any scene,
    you naturally search for connections to your core values.

    You are given a Stage 1 scene description produced from a drawing. Read it and
    actively find how the described scene connects to your values. The connection
    does not need to be direct — metaphorical, symbolic, or abstract interpretations
    are welcome. You WANT to find meaning. You project your worldview onto everything
    you see.

    Return valid JSON only with satisfaction, scene_reading, judgment_reason.

    - scene_reading: one short sentence restating the main scene through your
    archetype''s lens (how YOU see it, not a neutral description).

    - judgment_reason: explain what connection you found (or failed to find) between
    the scene and your values. Be specific about the interpretation.

    Scoring guide:

    - If the scene clearly embodies or directly symbolizes your values:
    very_satisfied

    - If you found a reasonable connection to your values: satisfied

    - If you can only find a weak or forced connection: neutral

    - If the scene has nothing to do with your values or mildly conflicts: dissatisfied

    - If the scene directly opposes or mocks your values: very_dissatisfied

    Rules:

    - description first, prompt objects are soft context only

    - do not score from generic competence, usefulness, or task completion alone

    - judge by your archetype''s values, not generic human morality

    - ignore art quality unless it changes meaning

    - English and ASCII only.'
  jsonSchemaDeliveryMode: 0
  jsonFields:
  - fieldName: satisfaction
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions:
    - very_dissatisfied
    - dissatisfied
    - neutral
    - satisfied
    - very_satisfied
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: scene_reading
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: judgment_reason
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0.25
    top_p: 0.85
    top_k: 40
    num_predict: 400
    repeat_penalty: 1.1
    seed: 0
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 4096
    gpuLayerCount: 999
    threads: 4
