  m_Script: {fileID: 11500000, guid: 03b52acd3da64abbb58ffeef4a98a876, type: 3}
  m_Name: AlienPreviewPipeline
  m_EditorClassIdentifier: Assembly-CSharp::PromptPipelineAsset
  displayName: AlienPreviewPipeline
  description: 'Stage 1: VLM free prose description. Stage 2: extract structured
    JSON fields from the prose.'
  steps:
  - stepName: AlienPreviewFree
    stepKind: 1
    llmProfile: {fileID: 11400000, guid: a8c7d2e1f3b45940b2e91d7a5c0f38b9, type: 2}
    userPromptTemplate: 'Describe everything visible in this drawing. What is happening?
      What are the figures doing? What actions or interactions are visible? Write vividly.

      ---

      For reference only — do not let this shape your description above.

      The player was asked to draw: {{target_objects}}

      After your free description, note whether Object A (first word) and Object
      B (second word) are visible, unclear, or missing.'
    jsonMaxRetries: 3
    jsonRetryDelaySeconds: 0.1
    useVision: 1
    imageStateKey: reference_image
    requireImage: 1
    resizeLongestSide: 768
    customLinkTypeName:
    customAsset: {fileID: 0}
    customLinkParameters: []
    editorPosition: {x: -16, y: -58}
    guid: 0d6af805-df2b-4e1b-807d-842970ff4b33
    nextStepGuid: c9e4f723-a51b-4d8e-b297-6f3c018a4e52
  - stepName: AlienPreviewExtract
    stepKind: 0
    llmProfile: {fileID: 11400000, guid: c3b5e7a914f2684d81e3c097b46fa201, type: 2}
    userPromptTemplate: 'Scene description:

      {{response}}

      Prompted objects: {{target_objects}}

      Extract the JSON fields from the description above.'
    jsonMaxRetries: 3
    jsonRetryDelaySeconds: 0.1
    useVision: 0
    imageStateKey:
    requireImage: 0
    resizeLongestSide: 768
