  displayName: AdjutantPreviewPipeline
  description: Generate a Stage 1 structured scene description directly from the
    drawing.
  steps:
  - stepName: AdjutantPreview
    stepKind: 0
    llmProfile: {fileID: 11400000, guid: f40e4c6dcfeff664bb7f044018b3e88f, type: 2}
    userPromptTemplate: 'Objects (soft context):

      {{target_objects}}

      Describe
      the visible drawing scene freely before any judgment.

      Cover what is
      present, what each thing seems to be doing, how the main elements relate, and
      the overall mood.

      Also report whether Object A and Object B are visible, unclear, or missing.
      Only mark visible when the drawing itself provides clear evidence.'
    jsonMaxRetries: 3
    jsonRetryDelaySeconds: 0.1
    useVision: 1
    imageStateKey: reference_image
    requireImage: 1
    resizeLongestSide: 768
    customLinkTypeName: SampleCustomLink, Assembly-CSharp, Version=0.0.0.0, Culture=neutral,
      PublicKeyToken=null
    customAsset: {fileID: 0}
    customLinkParameters:
    - key: name
      value: 
    - key: title
      value: 
    - key: level
      value: 
