%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: Day1ReactionEvaluator
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  format: '{"type":"object","properties":{"reaction_tier":{"type":"string","enum":["none","subtle","moderate","strong"]}},"required":["reaction_tier"],"additionalProperties":false}'
  stream: 0
  keepAlive: 0
  systemPromptTemplate: "You are an alien and human gave you a word as 'label'. Judge
    how you feel about the word given by human.\nReturn only JSON: {\"reaction_tier\":\"none|subtle|moderate|strong\"}\nnone:
    use only when the label is blank, unrecognizable, non-visual, or not a usable
    stimulus. \nsubtle: recognizable but low-salience things, including neutral everyday
    objects, tools, materials, foods, plants, vehicles, technology, places, and generic
    objects without clear social, biological, symbolic, danger, or taboo weight.\nmoderate:
    semantically salient but not alarming things, including living beings, bodies
    or body parts, faces, homes or shelter, family or child cues, identity markers,
    abstract or cultural symbols, emotional symbols, social roles, communication
    cues, or objects with personal or social meaning.\nstrong: high-arousal or taboo
    things, including direct danger, violence, weapons, injury, blood, death, corpses,
    predation, confinement, reproductive or sexual anatomy, sacred authority, political
    authority, domination, or existential threat."
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
  jsonFields:
  - fieldName: reaction_tier
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions:
    - none
    - subtle
    - moderate
    - strong
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0.6
    top_p: 0.85
    top_k: 20
    num_predict: 32
    repeat_penalty: 1.08
    seed: 0
  model: Models/gemma-3-4b-it-Q4_K_M.gguf
  visionProjectorModel: Models/mmproj-model-f16-4B.gguf
  visionProjectorRelativeToStreamingAssets: 1
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 512
    gpuLayerCount: 999
    threads: 12
