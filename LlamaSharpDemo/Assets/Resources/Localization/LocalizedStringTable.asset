%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4a2e6df8a44a4c49b7d2c3a5f0e1b6a8, type: 3}
  m_Name: LocalizedStringTable
  m_EditorClassIdentifier: Assembly-CSharp::DoodleDiplomacy.Localization.LocalizedStringTable
  entries:
  - key: speaker.science_officer
    sourceText: Science Officer
    translations:
    - locale: ko-KR
      text: "\uACFC\uD559 \uC7A5\uAD50"
  - key: speaker.adjutant
    sourceText: Adjutant
    translations:
    - locale: ko-KR
      text: "\uBD80\uAD00"
  - key: speaker.alien
    sourceText: Alien
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778"
  - key: speaker.system
    sourceText: System
    translations:
    - locale: ko-KR
      text: "\uC2DC\uC2A4\uD15C"
  - key: intro.adjutant.line1
    sourceText: Ambassador, the alien delegation has arrived.
    translations:
    - locale: ko-KR
      text: "\uB300\uC0AC\uB2D8, \uC678\uACC4 \uB300\uD45C\uB2E8\uC774 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - key: intro.adjutant.line2
    sourceText: 'They cannot understand our language.


      We must communicate
      through drawings.'
    translations:
    - locale: ko-KR
      text: "\uB9D0\uC500\uB4DC\uB9B0\uB300\uB85C \uC0AC\uBB3C\uC758 \uADF8\uB9BC\uC744
        \uADF8\uB824\uC8FC\uC2DC\uBA74 \uB429\uB2C8\uB2E4."
  - key: intro.adjutant.line3
    sourceText: Let's begin.
    translations:
    - locale: ko-KR
      text: "\uADF8\uB7FC \uC2DC\uC791\uD558\uACA0\uC2B5\uB2C8\uB2E4."
  - key: round.references.regenerating
    sourceText: Regenerating the object references with the same prompts...
    translations:
    - locale: ko-KR
      text: "\uAC19\uC740 \uD504\uB86C\uD504\uD2B8\uB85C \uCC38\uC870 \uBB3C\uCCB4\uB97C
        \uB2E4\uC2DC \uC0DD\uC131\uD558\uB294 \uC911\uC785\uB2C8\uB2E4..."
  - key: round.terminal.open_first
    sourceText: Open the terminal first.
    translations:
    - locale: ko-KR
      text: "\uBA3C\uC800 \uD130\uBBF8\uB110\uC744 \uC5EC\uC2ED\uC2DC\uC624."
  - key: round.adjutant.disabled
    sourceText: The adjutant can no longer review drawings. Click the alien for first-pass
      review.
    translations:
    - locale: ko-KR
      text: "\uBD80\uAD00\uC740 \uB354 \uC774\uC0C1 \uADF8\uB9BC\uC744 \uAC80\uD1A0\uD560
        \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. 1\uCC28 \uD310\uB3C5\uC744 \uBC1B\uC73C\uB824\uBA74
        \uC678\uACC4\uC778\uC744 \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.objects.generating
    sourceText: Generating the alien objects...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4 \uBB3C\uCCB4\uB97C \uC0DD\uC131\uD558\uB294 \uC911\uC785\uB2C8\uB2E4..."
  - key: round.objects.generator_missing
    sourceText: Object generator is missing. Assign AIPipelineBridge before starting
      the round.
    translations:
    - locale: ko-KR
      text: "\uC624\uBE0C\uC81D\uD2B8 \uC0DD\uC131\uAE30\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.
        \uB77C\uC6B4\uB4DC\uB97C \uC2DC\uC791\uD558\uAE30 \uC804\uC5D0 AIPipelineBridge\uB97C
        \uD560\uB2F9\uD558\uC2ED\uC2DC\uC624."
  - key: round.objects.generation_failed_retry
    sourceText: Object generation failed. Click the alien to retry.
    translations:
    - locale: ko-KR
      text: "\uC624\uBE0C\uC81D\uD2B8 \uC0DD\uC131\uC5D0 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4.
        \uC678\uACC4\uC778\uC744 \uD074\uB9AD\uD574 \uB2E4\uC2DC \uC2DC\uB3C4\uD558\uC2ED\uC2DC\uC624."
  - key: round.objects.generation_failed_prefix
    sourceText: 'Object generation failed: '
    translations:
    - locale: ko-KR
      text: "\uC624\uBE0C\uC81D\uD2B8 \uC0DD\uC131 \uC2E4\uD328: "
  - key: round.objects.presented_hint
    sourceText: Click the tablet to start drawing, or click the alien to regenerate
      the references.
    translations:
    - locale: ko-KR
      text: "\uADF8\uB9BC\uC744 \uC2DC\uC791\uD558\uB824\uBA74 \uD0DC\uBE14\uB9BF\uC744
        \uD074\uB9AD\uD558\uACE0, \uCC38\uC870 \uBB3C\uCCB4\uB97C \uB2E4\uC2DC \uC0DD\uC131\uD558\uB824\uBA74
        \uC678\uACC4\uC778\uC744 \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.preview.ready_hint
    sourceText: Click the alien to get a first-pass read, or click the tablet to
      keep drawing.
    translations:
    - locale: ko-KR
      text: "1\uCC28 \uD310\uB3C5\uC744 \uBC1B\uC73C\uB824\uBA74 \uC678\uACC4\uC778\uC744
        \uD074\uB9AD\uD558\uACE0, \uACC4\uC18D \uADF8\uB9AC\uB824\uBA74 \uD0DC\uBE14\uB9BF\uC744
        \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.preview.analyzing
    sourceText: The alien is trying to understand your drawing...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uC774 \uB300\uD1B5\uB839\uB2D8\uC758 \uADF8\uB9BC\uC744
        \uC774\uD574\uD558\uB824\uACE0 \uD569\uB2C8\uB2E4..."
  - key: round.preview.ai_analysis_unavailable
    sourceText: (AI analysis unavailable)
    translations:
    - locale: ko-KR
      text: "(AI \uBD84\uC11D \uBD88\uAC00)"
  - key: round.preview.ready_to_inspect
    sourceText: First-pass analysis is complete. Click the terminal to inspect the
      result.
    translations:
    - locale: ko-KR
      text: "1\uCC28 \uBD84\uC11D\uC774 \uC644\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
        \uACB0\uACFC\uB97C \uD655\uC778\uD558\uB824\uBA74 \uD130\uBBF8\uB110\uC744
        \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.submitting_hint
    sourceText: Submitting the drawing to the alien delegation...
    translations:
    - locale: ko-KR
      text: "\uADF8\uB9BC\uC744 \uC678\uACC4 \uB300\uD45C\uB2E8\uC5D0\uAC8C \uC81C\uCD9C\uD558\uB294
        \uC911\uC785\uB2C8\uB2E4..."
  - key: round.preview.terminal.fallback_analysis
    sourceText: (analysis unavailable)
    translations:
    - locale: ko-KR
      text: "(\uBD84\uC11D \uBD88\uAC00)"
  - key: round.preview.terminal.header
    sourceText: '[ALIEN FIRST PASS]'
    translations:
    - locale: ko-KR
      text: "[\uC678\uACC4\uC778 1\uCC28 \uD310\uB3C5]"
  - key: round.interpreter.signal_ready
    sourceText: A signal has reached the terminal. Click the terminal to inspect
      it.
    translations:
    - locale: ko-KR
      text: "\uC2E0\uD638\uAC00 \uD130\uBBF8\uB110\uC5D0 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4.
        \uD655\uC778\uD558\uB824\uBA74 \uD130\uBBF8\uB110\uC744 \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.interpreter.no_signal
    sourceText: No readable signal was recovered. Open the terminal to continue.
    translations:
    - locale: ko-KR
      text: "\uC77D\uC744 \uC218 \uC788\uB294 \uC2E0\uD638\uB97C \uBCF5\uAD6C\uD558\uC9C0
        \uBABB\uD588\uC2B5\uB2C8\uB2E4. \uACC4\uC18D\uD558\uB824\uBA74 \uD130\uBBF8\uB110\uC744
        \uC5EC\uC2ED\uC2DC\uC624."
  - key: round.interpreter.terminal.no_captured_signal
    sourceText: '[TRANSLATOR v1.0]

      > No captured alien signal.

      > _'
    translations:
    - locale: ko-KR
      text: "[\uBC88\uC5ED\uAE30 v1.0]\n> \uD3EC\uCC29\uB41C \uC678\uACC4 \uC2E0\uD638
        \uC5C6\uC74C.\n> _"
  - key: round.drawing.ready_hint
    sourceText: Press {key} when the drawing is ready to submit.
    translations:
    - locale: ko-KR
      text: "\uADF8\uB9BC\uC744 \uC81C\uCD9C\uD560 \uC900\uBE44\uAC00 \uB418\uBA74
        {key} \uD0A4\uB97C \uB204\uB974\uC2ED\uC2DC\uC624."
  - key: round.start.click_alien
    sourceText: Click the alien to begin the round.
    translations:
    - locale: ko-KR
      text: "\uB77C\uC6B4\uB4DC\uB97C \uC2DC\uC791\uD558\uB824\uBA74 \uC678\uACC4\uC778\uC744
        \uD074\uB9AD\uD558\uC2ED\uC2DC\uC624."
  - key: round.start.preparing_sd_server
    sourceText: Preparing the bundled SD server. Wait until the alien becomes interactable.
    translations:
    - locale: ko-KR
      text: "\uBC88\uB4E4 SD \uC11C\uBC84\uB97C \uC900\uBE44 \uC911\uC785\uB2C8\uB2E4.
        \uC678\uACC4\uC778\uACFC \uC0C1\uD638\uC791\uC6A9\uD560 \uC218 \uC788\uC744
        \uB54C\uAE4C\uC9C0 \uAE30\uB2E4\uB9AC\uC2ED\uC2DC\uC624."
  - key: round.start.object_generator_unavailable_prefix
    sourceText: 'Object generator unavailable: '
    translations:
    - locale: ko-KR
      text: "\uC624\uBE0C\uC81D\uD2B8 \uC0DD\uC131\uAE30 \uC0AC\uC6A9 \uBD88\uAC00: "
  - key: round.start.object_generator_not_ready
    sourceText: Object generator is not ready yet.
    translations:
    - locale: ko-KR
      text: "\uC624\uBE0C\uC81D\uD2B8 \uC0DD\uC131\uAE30\uAC00 \uC544\uC9C1 \uC900\uBE44\uB418\uC9C0
        \uC54A\uC558\uC2B5\uB2C8\uB2E4."
  - key: round.start.preparing_round_objects
    sourceText: Preparing the round objects. Wait until the alien becomes interactable.
    translations:
    - locale: ko-KR
      text: "\uB77C\uC6B4\uB4DC \uC624\uBE0C\uC81D\uD2B8\uB97C \uC900\uBE44 \uC911\uC785\uB2C8\uB2E4.
        \uC678\uACC4\uC778\uACFC \uC0C1\uD638\uC791\uC6A9\uD560 \uC218 \uC788\uC744
        \uB54C\uAE4C\uC9C0 \uAE30\uB2E4\uB9AC\uC2ED\uC2DC\uC624."
  - key: round.start.study_objects_and_click_alien
    sourceText: Study the two object images. Click the alien to begin the round.
    translations:
    - locale: ko-KR
      text: "\uB450 \uC624\uBE0C\uC81D\uD2B8 \uC774\uBBF8\uC9C0\uB97C \uC0B4\uD3B4\uBCF8
        \uB4A4 \uC678\uACC4\uC778\uC744 \uD074\uB9AD\uD574 \uB77C\uC6B4\uB4DC\uB97C
        \uC2DC\uC791\uD558\uC2ED\uC2DC\uC624."
  - key: round.llm.ready
    sourceText: LLM runtime is ready.
    translations:
    - locale: ko-KR
      text: "LLM \uB7F0\uD0C0\uC784\uC774 \uC900\uBE44\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
  - key: round.llm.loading
    sourceText: Loading LLM runtime. Game will start after preload completes.
    translations:
    - locale: ko-KR
      text: "LLM \uB7F0\uD0C0\uC784\uC744 \uBD88\uB7EC\uC624\uB294 \uC911\uC785\uB2C8\uB2E4.
        \uC0AC\uC804 \uB85C\uB4DC\uAC00 \uB05D\uB098\uBA74 \uAC8C\uC784\uC774 \uC2DC\uC791\uB429\uB2C8\uB2E4."
  - key: round.llm.preload_failed_prefix
    sourceText: 'LLM preload failed: '
    translations:
    - locale: ko-KR
      text: "LLM \uC0AC\uC804 \uB85C\uB4DC \uC2E4\uD328: "
  - key: round.llm.not_ready
    sourceText: LLM runtime is not ready yet.
    translations:
    - locale: ko-KR
      text: "LLM \uB7F0\uD0C0\uC784\uC774 \uC544\uC9C1 \uC900\uBE44\uB418\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
  - key: alien.reaction.mutter.very_dissatisfied
    sourceText: The aliens are conferring with each other...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uB4E4\uC774 \uC11C\uB85C \uD611\uC758\uD558\uACE0
        \uC788\uC2B5\uB2C8\uB2E4..."
  - key: alien.reaction.mutter.dissatisfied
    sourceText: The aliens exchange glances...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uB4E4\uC774 \uC2DC\uC120\uC744 \uC8FC\uACE0\uBC1B\uC2B5\uB2C8\uB2E4..."
  - key: alien.reaction.mutter.neutral
    sourceText: The aliens observe quietly...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uB4E4\uC774 \uC870\uC6A9\uD788 \uAD00\uCC30\uD569\uB2C8\uB2E4..."
  - key: alien.reaction.mutter.satisfied
    sourceText: The aliens murmur amongst themselves...
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uB4E4\uC774 \uB0AE\uAC8C \uC6C5\uC131\uAC70\uB9BD\uB2C8\uB2E4..."
  - key: alien.reaction.mutter.very_satisfied
    sourceText: The aliens react with visible excitement!
    translations:
    - locale: ko-KR
      text: "\uC678\uACC4\uC778\uB4E4\uC774 \uB208\uC5D0 \uB744\uAC8C \uD765\uBD84\uD55C
        \uBC18\uC751\uC744 \uBCF4\uC785\uB2C8\uB2E4!"
  - key: alien.reaction.narration.very_dissatisfied
    sourceText: They seem very displeased...
    translations:
    - locale: ko-KR
      text: "\uADF8\uB4E4\uC740 \uB9E4\uC6B0 \uBD88\uCF8C\uD574 \uBCF4\uC785\uB2C8\uB2E4..."
  - key: alien.reaction.narration.dissatisfied
    sourceText: They do not appear to like it.
    translations:
    - locale: ko-KR
      text: "\uADF8\uB4E4\uC740 \uB9C8\uC74C\uC5D0 \uB4E4\uC5B4 \uD558\uC9C0 \uC54A\uB294
        \uAC83 \uAC19\uC2B5\uB2C8\uB2E4."
  - key: alien.reaction.narration.neutral
    sourceText: Not much of a reaction.
    translations:
    - locale: ko-KR
      text: "\uBC18\uC751\uC740 \uD06C\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
  - key: alien.reaction.narration.satisfied
    sourceText: A positive response.
    translations:
    - locale: ko-KR
      text: "\uAE0D\uC815\uC801\uC778 \uBC18\uC751\uC785\uB2C8\uB2E4."
  - key: alien.reaction.narration.very_satisfied
    sourceText: They seem quite impressed!
    translations:
    - locale: ko-KR
      text: "\uADF8\uB4E4\uC740 \uAF64 \uAE4A\uC740 \uC778\uC0C1\uC744 \uBC1B\uC740
        \uAC83 \uAC19\uC2B5\uB2C8\uB2E4!"
  - key: ui.title.start
    sourceText: START
    translations:
    - locale: ko-KR
      text: "\uC2DC\uC791"
  - key: ui.title.settings
    sourceText: SETTINGS
    translations:
    - locale: ko-KR
      text: "\uC124\uC815"
  - key: ui.settings.title
    sourceText: Settings
    translations:
    - locale: ko-KR
      text: "\uC124\uC815"
  - key: ui.settings.language
    sourceText: Language
    translations:
    - locale: ko-KR
      text: "\uC5B8\uC5B4"
  - key: ui.settings.english
    sourceText: English
    translations:
    - locale: ko-KR
      text: English
  - key: ui.settings.korean
    sourceText: Korean
    translations:
    - locale: ko-KR
      text: "\uD55C\uAD6D\uC5B4"
  - key: ui.settings.back
    sourceText: Back
    translations:
    - locale: ko-KR
      text: "\uB4A4\uB85C"
  - key: ui.preview.submit
    sourceText: SUBMIT
    translations:
    - locale: ko-KR
      text: "\uC81C\uCD9C"
  - key: ui.preview.modify
    sourceText: MODIFY
    translations:
    - locale: ko-KR
      text: "\uC218\uC815"
  - key: ui.day1.submit
    sourceText: Submit
    translations:
    - locale: ko-KR
      text: "\uC81C\uCD9C"
  - key: ui.day1.confirm
    sourceText: Confirm
    translations:
    - locale: ko-KR
      text: "\uD655\uC778"
  - key: ui.day1.redraw
    sourceText: Redraw
    translations:
    - locale: ko-KR
      text: "\uB2E4\uC2DC \uADF8\uB9AC\uAE30"
  - key: day1.opening.1
    sourceText: Mr. President, draw one simple picture on the tablet.
    translations:
    - locale: ko-KR
      text: "\uB300\uD1B5\uB839\uB2D8, \uC678\uACC4\uC778 \uB300\uD45C\uB2E8\uC774
        \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4."
  - key: day1.opening.2
    sourceText: The delegation will only see the completed image. Not the drawing
      process.
    translations:
    - locale: ko-KR
      text: "\uB9D0\uC500 \uB4DC\uB9B0\uB300\uB85C \uAC04\uB2E8\uD55C \uB2E8\uC77C
        \uC0AC\uBB3C\uC744 \uADF8\uB9AC\uC2DC\uBA74 \uC800\uB4E4\uC774 \uADF8\uB9BC\uC744
        \uBCFC \uB54C \uBC1C\uC0DD\uD558\uB294 \uB1CC\uD30C\uB97C \uCE21\uC815\uD574
        \uC6B0\uB9AC\uC758 \uC5B8\uC5B4\uC640 \uB9E4\uD551\uD558\uB294 \uACFC\uC815\uC785\uB2C8\uB2E4."
  - key: day1.opening.3
    sourceText: The apparatus will classify the image before transmission. Once the
      label is confirmed, we will show it to them and record the response.
    translations:
    - locale: ko-KR
      text: "\uC624\uC9C1 \uD55C\uAC00\uC9C0 \uC885\uB958\uC758 \uC0AC\uBB3C\uC744
        \uC0C9\uAE54\uACFC \uD568\uAED8 \uBA85\uD655\uD55C \uD615\uD0DC\uB85C \uADF8\uB824\uC8FC\uC2DC\uBA74
        \uB354 \uC815\uD655\uD55C \uB370\uC774\uD130\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - key: day1.tablet_blank
    sourceText: The tablet is blank, Mr. President. Please draw one picture by itself.
    translations:
    - locale: ko-KR
      text: "\uD0DC\uBE14\uB9BF\uC774 \uBE44\uC5B4 \uC788\uC2B5\uB2C8\uB2E4, \uB300\uD1B5\uB839\uB2D8.
        \uC798\uBABB \uB204\uB974\uC2E0\uAC78\uAE4C\uC694?"
  - key: day1.scanning
    sourceText: Scanning drawing. Hold transmission.
    translations:
    - locale: ko-KR
      text: "\uADF8\uB9BC\uC744 \uC2A4\uCE94 \uC911\uC785\uB2C8\uB2E4. "
  - key: day1.classification_unstable
    sourceText: Classification unstable. The response data would be contaminated.
      Please redraw.
    translations:
    - locale: ko-KR
      text: "\uC77C\uBC18\uC801\uC778 \uC0AC\uBB3C\uC744 \uC0C9\uC744 \uD65C\uC6A9\uD558\uACE0
        \uD615\uD0DC\uB97C \uB354 \uBA85\uD655\uD558\uAC8C \uADF8\uB824\uC8FC\uC2DC\uBA74
        \uCE21\uC815 \uC815\uD655\uB3C4\uAC00 \uB354 \uB192\uC544\uC9D1\uB2C8\uB2E4."
  - key: day1.written_text_detected
    sourceText: Written text, letters, or symbols detected. The apparatus cannot
      calibrate language input this way. Please draw one picture instead.
    translations:
    - locale: ko-KR
      text: "\uBB38\uC790\uB85C \uC18C\uD1B5\uD560 \uC218 \uC788\uC5C8\uC73C\uBA74
        \uC800\uB3C4 \uC815\uB9D0 \uC88B\uACA0\uB124\uC694. \uC0AC\uBB3C \uADF8\uB9BC\uC744
        \uADF8\uB824\uC8FC\uC154\uC57C \uBC88\uC5ED\uAE30\uB97C \uB9CC\uB4E4 \uC218
        \uC788\uC2B5\uB2C8\uB2E4 \uB300\uD1B5\uB839\uB2D8."
  - key: day1.non_stimulus_detected
    sourceText: The apparatus cannot calibrate blank marks, simple lines, dots, islands,
      letters, written symbols, or basic geometric shapes. Please draw one recognizable
      object.
    translations:
    - locale: ko-KR
      text: "\uC0AC\uBB3C\uC744 \uD558\uB098 \uADF8\uB824\uC8FC\uC2ED\uC2DC\uC624."
  - key: day1.action_or_scene_detected
    sourceText: 'Action or scene detected: {label}. Day 1 calibration only accepts
      still objects or repeated copies of one object.'
    translations:
    - locale: ko-KR
      text: "\uBCF5\uC7A1\uD55C \uC7A5\uBA74\uC740 \uB1CC\uD30C \uAC10\uC9C0 \uACB0\uACFC\uB97C
        \uBD80\uC815\uD655\uD558\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4. \uB2E8\uC77C \uC0AC\uBB3C\uC744
        \uD558\uB098\uB9CC \uADF8\uB824\uC8FC\uC154\uC57C \uD569\uB2C8\uB2E4."
  - key: day1.multiple_objects_detected
    sourceText: 'Multiple object types detected: {label}. Please draw one recognizable
      concept, or repeated copies of the same thing.'
    translations:
    - locale: ko-KR
      text: "{label} \uB4E4\uC744 \uADF8\uB9AC\uC2E0\uAC74\uAC00\uC694? \uC9C0\uAE08
        \uB2E8\uACC4\uC5D0\uC11C\uB294 \uD558\uB098\uC758 \uC885\uB958\uC758 \uC0AC\uBB3C\uB9CC
        \uADF8\uB824\uC8FC\uC154\uC57C \uC815\uD655\uD55C \uB1CC\uD30C \uB9E4\uD551
        \uB370\uC774\uD130\uB97C \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4 \uAC01\uD558."
  - key: day1.identifies_drawing
    sourceText: 'The apparatus identifies this drawing as: {label}. Confirm the transmission
      label.'
    translations:
    - locale: ko-KR
      text: "{label}\uC744 \uADF8\uB9AC\uC2E0 \uAC8C \uB9DE\uB098\uC694? "
  - key: day1.previous_image_not_transmitted
    sourceText: Understood. The previous image will not be transmitted.
    translations:
    - locale: ko-KR
      text: "\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uC900\uBE44\uAC00 \uC644\uB8CC\uB418\uBA74
        \uC81C\uCD9C\uD574\uC8FC\uC2ED\uC2DC\uC624."
  - key: day1.terminal.transmission_active
    sourceText: 'TRANSMISSION ACTIVE

      DRAWING: {label}

      RESPONSE MONITORING
      ONLINE'
    translations:
    - locale: ko-KR
      text: "\uC1A1\uC2E0 \uD65C\uC131\uD654\n\uADF8\uB9BC: {label}\n\uC751\uB2F5
        \uAC10\uC2DC \uC628\uB77C\uC778"
  - key: day1.transmission_label_confirmed
    sourceText: 'Transmission label confirmed: {label}. Presenting drawing to the
      delegation.'
    translations:
    - locale: ko-KR
      text: "\uADF8\uB824\uC8FC\uC2E0 {label} \uADF8\uB9BC\uC744 \uC81C\uCD9C\uD558\uACA0\uC2B5\uB2C8\uB2E4."
  - key: day1.reaction_evaluation_unstable
    sourceText: Response monitor unstable. Try the transmission again.
    translations:
    - locale: ko-KR
      text: "\uBC18\uC751 \uAC10\uC2DC\uC7A5\uCE58\uAC00 \uBD88\uC548\uC815\uD569\uB2C8\uB2E4.
        \uC1A1\uC2E0\uC744 \uB2E4\uC2DC \uC2DC\uB3C4\uD558\uC2ED\uC2DC\uC624."
  - key: day1.response_pattern_logged
    sourceText: Response pattern logged. Next drawing, Mr. President.
    translations:
    - locale: ko-KR
      text: "\uBC18\uC751 \uD328\uD134\uC744 \uAE30\uB85D\uD588\uC2B5\uB2C8\uB2E4.
        \uB2E4\uC74C \uADF8\uB9BC\uC744 \uADF8\uB824\uC8FC\uC2DC\uC8E0, \uB300\uD1B5\uB839\uB2D8."
  - key: day1.complete.1
    sourceText: Calibration set complete. The interpreter now has a preliminary visual-response
      map.
    translations:
    - locale: ko-KR
      text: "\uBCF4\uC815 \uC138\uD2B8\uAC00 \uC644\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
        \uD1B5\uC5ED\uAE30\uB294 \uC774\uC81C \uC608\uBE44 \uC2DC\uAC01 \uBC18\uC751
        \uC9C0\uB3C4\uB97C \uD655\uBCF4\uD588\uC2B5\uB2C8\uB2E4."
  - key: day1.complete.2
    sourceText: These images will remain in the drawing library. We may need them
      again tomorrow.
    translations:
    - locale: ko-KR
      text: "\uC774 \uC774\uBBF8\uC9C0\uB4E4\uC740 \uADF8\uB9BC \uB77C\uC774\uBE0C\uB7EC\uB9AC\uC5D0
        \uB0A8\uC2B5\uB2C8\uB2E4. \uB0B4\uC77C \uB2E4\uC2DC \uD544\uC694\uD560 \uC218
        \uC788\uC2B5\uB2C8\uB2E4."
  - key: day1.complete.3
    sourceText: We have enough data for the interpreter.
    translations:
    - locale: ko-KR
      text: "\uD1B5\uC5ED\uAE30\uC5D0 \uD544\uC694\uD55C \uB370\uC774\uD130\uB294
        \uCDA9\uBD84\uD569\uB2C8\uB2E4."
  - key: day1.complete.4
    sourceText: 'I should warn you, Mr. President: they did not simply look at the
      images. They reacted to your choices.'
    translations:
    - locale: ko-KR
      text: "\uACBD\uACE0\uB4DC\uB824\uC57C\uACA0\uC2B5\uB2C8\uB2E4, \uB300\uD1B5\uB839\uB2D8.
        \uADF8\uB4E4\uC740 \uC774\uBBF8\uC9C0\uB97C \uB2E8\uC21C\uD788 \uBCF8 \uAC83\uC774
        \uC544\uB2D9\uB2C8\uB2E4. \uB300\uD1B5\uB839\uB2D8\uC758 \uC120\uD0DD\uC5D0
        \uBC18\uC751\uD588\uC2B5\uB2C8\uB2E4."
  - key: day1.reaction.none
    sourceText: Minimal response. Logging baseline pattern.
    translations:
    - locale: ko-KR
      text: "\uBCC4\uBC18\uC751\uC774 \uC5C6\uC5B4 \uBCF4\uC774\uB124\uC694. \uB1CC\uD30C\uB294
        \uC798 \uCE21\uC815\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
  - key: day1.reaction.subtle
    sourceText: Subtle response from the delegation. Logging association pattern.
    translations:
    - locale: ko-KR
      text: "\uBBF8\uBB18\uD558\uB124\uC694. \uB1CC\uD30C \uCE21\uC815\uAC12\uC740
        \uC798 \uAE30\uB85D\uD574\uB450\uC5C8\uC2B5\uB2C8\uB2E4."
  - key: day1.reaction.moderate
    sourceText: Moderate cross-delegate activity. The drawing registered clearly.
    translations:
    - locale: ko-KR
      text: "\uB098\uC058\uC9C0 \uC54A\uC558\uB098\uBD05\uB2C8\uB2E4. \uBB34\uC2A8
        \uC598\uAE30\uB97C \uD558\uACE0\uC788\uB294\uAC78\uAE4C\uC694? \uB1CC\uD30C
        \uBC18\uC751\uC740 \uC798 \uCE21\uC815\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
  - key: day1.reaction.strong
    sourceText: Strong response. All three delegates reacted to the drawing.
    translations:
    - locale: ko-KR
      text: "\uAC15\uD55C \uBC18\uC751\uC744 \uBCF4\uC774\uB294\uAD70\uC694. \uB1CC\uD30C\uB3C4
        \uC815\uC0C1 \uCE21\uC815\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uB1CC\uD30C \uBC18\uC751\uC774
        \uC720\uB09C\uD788 \uC120\uBA85\uD569\uB2C8\uB2E4."
  - key: label.blank
    sourceText: blank
    translations:
    - locale: ko-KR
      text: "\uBE48 \uADF8\uB9BC"
  - key: label.written_text
    sourceText: written text
