%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: Day1StimulusClassifier
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  format: '{"type":"object","properties":{"object_count":{"type":"number"},"label":{"type":"string","minLength":1}},"required":["object_count","label"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  systemPromptTemplate: "Classify the completed drawing by visual appearance only.\r\n\r\nReturn
    only JSON:\r\n{\"object_count\":number,\"label\":\"short lowercase noun phrase\"}\r\n\r\nRules:\r\n-
    Count distinct main visual items, not parts of one item.\r\n- One object,
    symbol, icon, body part, face, house, flag, or abstract mark counts as 1.\r\n-
    Multiple separate meaningful objects count as more than 1; label them briefly,
    such as \"apple and knife\".\r\n- If the drawing is primarily letters, numbers,
    handwriting, or words, return {\"object_count\":1,\"label\":\"written text\"}.\r\n-
    If written text appears with another visual item, count it separately and include
    \"written text\" in the label, such as \"apple and written text\".\r\n- If blank
    or mostly empty, return {\"object_count\":0,\"label\":\"blank\"}.\r\n- For unclear
    or abstract drawings, use a broad visual label such as \"abstract symbol\",
    \"geometric mark\", \"body part\", or \"organic symbol\".\r\n- Do not infer story,
    intention, psychology, or morality.\r\n- Do not add fields, markdown, confidence,
    tags, or explanation."
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
  jsonFields:
  - fieldName: object_count
    fieldType: 1
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: label
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 1
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0
    top_p: 0.9
    top_k: 20
    num_predict: 220
    repeat_penalty: 1.05
    seed: 0
  model: Models/gemma-3-4b-it-Q4_K_M.gguf
  visionProjectorModel: Models/mmproj-model-f16.gguf
  visionProjectorRelativeToStreamingAssets: 1
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 2048
    gpuLayerCount: 32
    threads: 12
