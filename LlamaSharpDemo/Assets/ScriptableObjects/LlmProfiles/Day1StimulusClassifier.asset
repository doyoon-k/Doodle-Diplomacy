%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 89613a69694243bf833fbdc251da5b5d, type: 3}
  m_Name: Day1StimulusClassifier
  m_EditorClassIdentifier: Assembly-CSharp::LlmGenerationProfile
  format: '{"type":"object","properties":{"object_count":{"type":"number"},"label":{"type":"string","minLength":1}},"required":["object_count","label"],"additionalProperties":false}'
  stream: 0
  keepAlive: 
  systemPromptTemplate: 'Classify the drawing by visual appearance only. Return
    only JSON:

    {"object_count":number,"label":"short lowercase English label"}

    Rules:

    - Count separate depicted subjects, not parts or details.

    - Label must
    stay English.

    - Same kind repeated: use one plural concept label, e.g. "apples",
    "eyes", "breasts".

    - Different kinds: join distinct labels with "and",
    e.g. "apple and banana".

    - Action, movement, relationship, or scene:
    {"object_count":0,"label":"action or scene"}.

    - Text or handwriting:
    label "written text"; if with an object, include "and written text".

    -
    Blank or mostly empty: {"object_count":0,"label":"blank"}.'
  jsonSchemaDeliveryMode: 0
  thinkingMode: 0
  jsonFields:
  - fieldName: object_count
    fieldType: 1
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 
    maxLength: 
    minItems: 
    maxItems: 
  - fieldName: label
    fieldType: 0
    arrayElementType: 0
    children: []
    enumOptions: []
    minValue: 
    maxValue: 
    minLength: 1
    maxLength: 
    minItems: 
    maxItems: 
  modelParams:
    temperature: 0
    top_p: 0.9
    top_k: 20
    num_predict: 128
    repeat_penalty: 1.05
    seed: 0
  model: Models/gemma-3-4b-it-Q4_K_M.gguf
  visionProjectorModel: Models/mmproj-model-f16.gguf
  visionProjectorRelativeToStreamingAssets: 1
  runtimeParams:
    modelPathRelativeToStreamingAssets: 1
    contextSize: 2048
    gpuLayerCount: 999
    threads: 12
